# Nestly AI configuration
# Both variables are optional — without ANTHROPIC_API_KEY the app runs the
# free local mock analyzer (no paid AI calls are ever made).

# Anthropic API key for real document analysis (server-side only, never
# exposed to the client). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Recommended: a shared family access code. When set, AI requests must send
# this code (entered once per device in Settings). Protects your API credit
# while the app has no sign-in.
NESTLY_AI_ACCESS_CODE=
