# Nestly AI — Google Gemini is the primary provider.
# Setting GEMINI_API_KEY is enough to enable live analysis (free key at aistudio.google.com/apikey).
AI_ENABLED=true
GEMINI_API_KEY=
# Optional: override the model (default: gemini-3.5-flash) or force mock/disabled for testing
GEMINI_MODEL=
AI_PROVIDER=

# Google authentication, optional until production auth is enabled
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Optional aliases accepted by the app/auth library
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Optional alternative AI provider for document classification (used only when GEMINI_API_KEY is not set)
ANTHROPIC_API_KEY=
# Family access code required for paid AI calls (recommended)
NESTLY_AI_ACCESS_CODE=

# Closed beta and collaboration flags
NEXT_PUBLIC_NESTLY_CLOSED_BETA_ENABLED=false
NEXT_PUBLIC_NESTLY_BETA_LABEL=Nestly Beta
NEXT_PUBLIC_NESTLY_FEATURE_FAMILY_INVITATIONS=false
NEXT_PUBLIC_NESTLY_FEATURE_SECURE_DOCUMENTS=false
NEXT_PUBLIC_NESTLY_FEATURE_REALTIME_SHOPPING=false
NEXT_PUBLIC_NESTLY_FEATURE_REALTIME_TASKS=false
NEXT_PUBLIC_NESTLY_FEATURE_ASSISTANT=true
NEXT_PUBLIC_NESTLY_FEATURE_PROACTIVE_AI=false
NEXT_PUBLIC_NESTLY_FEATURE_MULTIPLE_FAMILY_SPACES=false
NEXT_PUBLIC_NESTLY_FEATURE_EMAIL_NOTIFICATIONS=false
NEXT_PUBLIC_NESTLY_FEATURE_CLOSED_BETA_FEEDBACK=true
NEXT_PUBLIC_NESTLY_FEATURE_CLOUD_PERSISTENCE=false
NEXT_PUBLIC_NESTLY_FEATURE_AUTOMATIONS=false
NEXT_PUBLIC_NESTLY_FEATURE_SMART_TEMPLATES=true
NEXT_PUBLIC_NESTLY_FEATURE_SMART_COLLECTIONS=true
NEXT_PUBLIC_NESTLY_FEATURE_IMPORT_EXPORT=false
NEXT_PUBLIC_NESTLY_FEATURE_ADVANCED_BACKUP=true
NEXT_PUBLIC_NESTLY_FEATURE_OFFLINE_QUEUE=false
NEXT_PUBLIC_NESTLY_FEATURE_RELEASE_NOTES=true

# Planned production backend: Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=nestly-private

# Planned production email provider
EMAIL_PROVIDER=mock
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
